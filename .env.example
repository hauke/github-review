# Copy this to .env and fill in your values

# GitHub personal access token (read-only access is sufficient — public_repo or repo scope)
GITHUB_TOKEN=ghp_your_token_here

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Claude model to use (default: claude-sonnet-4-6; use claude-opus-4-6 for harder PRs)
# CLAUDE_MODEL=claude-sonnet-4-6

# Maximum tokens in the review output (default: 8192)
# CLAUDE_MAX_TOKENS=8192

# Maximum prompt size in characters before truncation (default: 120000 ≈ ~30k tokens)
# MAX_PROMPT_CHARS=120000

# Comma-separated list of GitHub organisations whose PRs are allowed
ALLOWED_ORGS=myorg,anotheraporg

# Flask secret key (change this to a random string)
FLASK_SECRET_KEY=change-me-to-something-random
